# Copy this file to .env and fill in real values.
# NEVER commit a real .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_THIS@db:5432/call_analytics
# Used by docker-compose to set the postgres container's password.
POSTGRES_PASSWORD=CHANGE_THIS

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
WHISPER_MODEL=whisper-1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABC...
# Comma-separated Telegram IDs of admins (receive system error alerts)
ADMIN_TELEGRAM_IDS=123456789,987654321

# ── Yandex Cloud S3 ───────────────────────────────────────────────────────────
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=call-analytics-files
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=ru-central1
S3_KEY_PREFIX=calls

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate real secrets with:  python -c "import secrets; print(secrets.token_hex(32))"
# Placeholders (anything starting with "change-me") are REJECTED at startup.
# Minimum length: 16 characters.
JWT_SECRET_KEY=REPLACE_WITH_token_hex_32
# Token lifetime. Default is 1 day (1440 min). Since the token is stored in
# localStorage (XSS-vulnerable), keep this short. Migrate to httpOnly cookies
# before exposing the panel to the public internet.
JWT_EXPIRE_MINUTES=1440

# Pre-shared secret between the bot and the API (X-Bot-Secret header on /api/calls/upload).
BOT_SECRET=REPLACE_WITH_token_hex_32

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of web origins allowed to call the API from a browser.
# In the default docker-compose setup, nginx proxies /api on the same origin,
# so CORS is not exercised. Only needed when panel and API are on different
# origins (e.g. local Vite dev server on :5173 → API on :8000).
CORS_ORIGINS=http://localhost:5173

# ── Process roles ─────────────────────────────────────────────────────────────
# Exactly one process must set RUN_BOT=true (one Telegram poller per token).
# Exactly one process must set RUN_WORKER=true (single in-memory task queue).
# API can be scaled horizontally (RUN_API=true on every API instance).
RUN_API=true
RUN_BOT=false
RUN_WORKER=false
# Base URL the bot uses to reach the API for /api/calls/upload.
# In docker-compose this is http://api:8000; standalone it's http://localhost:8000.
INTERNAL_API_URL=http://localhost:8000
# URL the API uses to signal the worker when a new call is uploaded.
# In docker-compose: http://worker:8000. Leave empty if worker runs in same process.
WORKER_URL=

# ── Processing ────────────────────────────────────────────────────────────────
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=5.0
MIN_TRANSCRIPTION_LENGTH=10
# FFMPEG_PATH=/usr/bin/ffmpeg  # uncomment if ffmpeg is not in PATH
TEMP_DIR=/tmp/call-analytics

# ── App ───────────────────────────────────────────────────────────────────────
# DEBUG=true also triggers init_db() on startup (dev only — never enable in prod;
# use Alembic migrations instead). Also enables /api/docs and /api/redoc.
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
